{
  "manifest_version": 3,
  "name": "EverythingConvert — Quick File Converter",
  "version": "1.0.0",
  "description": "Convert PDFs, images, video & more in your browser. Right-click an image or open the popup to launch the right free tool.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "EverythingConvert — Quick File Converter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus"]
}
