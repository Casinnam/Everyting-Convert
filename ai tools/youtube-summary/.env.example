# ── ai-youtube-summary edge function secrets ──
# Set these with:  supabase secrets set KEY=value

# Required
OPENAI_API_KEY=
USAGE_IDENTITY_SALT=
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically by Supabase.

# Optional
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Recommended paid transcript provider: Supadata (https://supadata.ai).
# Just set the API key — the function auto-uses Supadata when this is present,
# and falls back to the built-in scraper if it fails. SUPADATA_API_URL is
# optional (defaults to the public endpoint).
SUPADATA_API_KEY=
# SUPADATA_API_URL=https://api.supadata.ai/v1/transcript

# Alternative: any other paid transcript API (generic adapter). The built-in
# YouTube caption scraper is often rate-limited/blocked from datacenter IPs,
# so a paid provider is strongly recommended for production.
TRANSCRIPT_API_URL=
TRANSCRIPT_API_KEY=
